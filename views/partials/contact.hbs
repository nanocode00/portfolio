<section id="contact" class="contact-section scroll-section" aria-labelledby="contact-section-title">
  <div class="section-container max-width">
    <!-- Section Title -->
    <div class="section-header">
      <span class="section-subtitle">GET IN TOUCH</span>
      <h2 id="contact-section-title" class="section-title">프로젝트 연락처 및 링크</h2>
      <p class="section-description">
        기술의 가치를 제품으로 꽃피우는 신뢰성 있는 협업 파트너입니다. 궁금한 점이 있으시거나 제품 개발 프로젝트 협업이 필요하시다면 언제든 연락해 주시기 바랍니다.
      </p>
    </div>

    <!-- Contact Grid Card -->
    <div class="contact-card-box">
      <div class="contact-card-info">
        <h3 class="contact-card-heading">함께 새로운 가치를 만듭니다</h3>
        <p class="contact-card-text">
          AI 탐지 로직의 제품화 설계, 모바일 온디바이스 개발 및 IoT 임베디드 회로 수직 통합 등 언제나 새로운 도전을 적극적으로 환영합니다.
        </p>
        <div class="contact-status-online">
          <span class="status-pulse"></span>
          <span class="status-text">프로젝트 제안 및 상시 채용 협의 가능</span>
        </div>
      </div>

      <!-- Links Wrapper -->
      <div class="contact-links-grid">
        <!-- Email Link -->
        <a 
          href="mailto:rwg0901@naver.com" 
          class="contact-button-link" 
          id="contact-email-link"
          data-type="이메일" 
          data-value="rwg0901@naver.com"
          aria-label="이메일 보내기 (rwg0901@naver.com)"
        >
          <div class="link-icon">✉️</div>
          <div class="link-details">
            <span class="link-label">Email 주소</span>
            <span class="link-value" id="email-val">rwg0901@naver.com</span>
          </div>
          <span class="link-arrow">→</span>
        </a>

        <!-- GitHub Link -->
        <a 
          href="https://github.com/nanocode00" 
          target="_blank" 
          rel="noopener noreferrer" 
          class="contact-button-link" 
          id="contact-github-link"
          data-type="GitHub" 
          data-value="https://github.com/nanocode00"
          aria-label="GitHub 주소 방문 (github.com/nanocode00)"
        >
          <div class="link-icon">🐙</div>
          <div class="link-details">
            <span class="link-label">GitHub 저장소</span>
            <span class="link-value" id="github-val">github.com/nanocode00</span>
          </div>
          <span class="link-arrow">→</span>
        </a>

        <!-- Resume Notice (Disabled/Non-clickable) -->
        <div 
          class="contact-button-info-disabled" 
          id="contact-resume-info"
          aria-label="이력서 안내"
        >
          <div class="link-icon">📄</div>
          <div class="link-details">
            <span class="link-label-disabled">온라인 이력서</span>
            <span class="link-value-disabled">이력서 PDF는 현재 정리 중입니다. 자세한 내용은 이메일로 문의해 주세요.</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Alert Modal Banner (hidden by default) -->
    <div class="placeholder-alert-overlay" id="alert-modal" aria-hidden="true" role="dialog" aria-labelledby="alert-title">
      <div class="placeholder-alert-card">
        <div class="alert-icon">⚠️</div>
        <h4 id="alert-title" class="alert-card-title">안내 메시지</h4>
        <p class="alert-card-text" id="alert-message-text">이 정보는 플레이스홀더 상태입니다.</p>
        <button class="btn btn-primary" id="alert-close-btn" aria-label="안내 메시지 닫기">확인</button>
      </div>
    </div>

  </div>
</section>
