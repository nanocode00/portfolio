<header id="portfolio-header" class="header-container">
  <div class="header-inner max-width">
    <!-- Logo -->
    <a href="#hero" class="logo-link" id="logo-id">
      <span class="logo-name">{{portfolio.name}}</span>
      <span class="logo-separator">|</span>
      <span class="logo-title">AI Product Engineer</span>
    </a>

    <!-- Desktop Navigation -->
    <nav class="desktop-nav" aria-label="메인 내비게이션">
      <ul class="nav-list">
        <li><a href="#hero" class="nav-item active" id="nav-hero-id">소개</a></li>
        <li><a href="#projects" class="nav-item" id="nav-projects-id">프로젝트</a></li>
        <li><a href="#skills" class="nav-item" id="nav-skills-id">기술</a></li>
        <li><a href="#experience" class="nav-item" id="nav-experience-id">경험</a></li>
        <li><a href="#chat" class="nav-item" id="nav-chat-id">챗</a></li>
        <li><a href="#contact" class="nav-item" id="nav-contact-id">연락처</a></li>
      </ul>
    </nav>

    <!-- Mobile Menu Button -->
    <button class="mobile-menu-toggle" id="menu-toggle-btn" aria-expanded="false" aria-controls="mobile-menu" aria-label="메뉴 열기">
      <span class="hamburger-line line-1"></span>
      <span class="hamburger-line line-2"></span>
      <span class="hamburger-line line-3"></span>
    </button>
  </div>

  <!-- Mobile Drawer Menu -->
  <div class="mobile-menu-drawer" id="mobile-menu" aria-hidden="true">
    <nav class="mobile-nav" aria-label="모바일 내비게이션">
      <ul class="mobile-nav-list">
        <li><a href="#hero" class="mobile-nav-item" id="mob-nav-hero-id">소개</a></li>
        <li><a href="#projects" class="mobile-nav-item" id="mob-nav-projects-id">프로젝트</a></li>
        <li><a href="#skills" class="mobile-nav-item" id="mob-nav-skills-id">기술</a></li>
        <li><a href="#experience" class="mobile-nav-item" id="mob-nav-experience-id">경험</a></li>
        <li><a href="#chat" class="mobile-nav-item" id="mob-nav-chat-id">챗</a></li>
        <li><a href="#contact" class="mobile-nav-item" id="mob-nav-contact-id">연락처</a></li>
      </ul>
    </nav>
  </div>
</header>
